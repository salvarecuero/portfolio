---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { presentation } from "../data/presentation";

interface Props {
  entry: CollectionEntry<"projects">;
}
const { entry } = Astro.props;
const { title, summary, stack, links, media, accent } = entry.data;
// Per-Project identity: the page wears the Project's accent (token override, like the
// Showcase chrome). Falls back to the global --accent when a Project sets none.
const rootStyle = accent ? `--accent:${accent}` : undefined;
---

<main class="project" style={rootStyle}>
  <div class="shell">
    <a class="back back--top" href="/">
      <span class="arrow" aria-hidden="true">←</span> {presentation.name}
    </a>

    <article>
      <header class="head">
        <p class="eyebrow">Project</p>
        <h1>{title}</h1>
        <p class="summary">{summary}</p>

        {(stack.length > 0 || links?.live || links?.repo) && (
          <div class="meta">
            {stack.length > 0 && (
              <ul class="stack" aria-label="Stack">
                {stack.map((t) => <li>{t}</li>)}
              </ul>
            )}

            {(links?.live || links?.repo) && (
              <nav class="links" aria-label="Project links">
                {links?.live && (
                  <a class="pill" href={links.live} target="_blank" rel="noopener">
                    Live site <span class="ext" aria-hidden="true">↗</span>
                  </a>
                )}
                {links?.repo && (
                  <a class="pill" href={links.repo} target="_blank" rel="noopener">
                    Repository <span class="ext" aria-hidden="true">↗</span>
                  </a>
                )}
              </nav>
            )}
          </div>
        )}
      </header>

      <div class="media">
        {media.map((m) =>
          m.type === "image" ? (
            <Image
              class="frame"
              src={m.src}
              alt={m.alt}
              widths={[480, 960, 1440]}
              sizes="(max-width: 860px) 100vw, 820px"
            />
          ) : (
            <video class="frame" controls playsinline poster={m.poster.src} aria-label={m.alt}>
              {m.sources.map((s) => <source src={s.src} type={s.type} />)}
            </video>
          )
        )}
      </div>

      <div class="body">
        <slot />
      </div>

      <footer class="foot">
        <a class="back" href="/">
          <span class="arrow" aria-hidden="true">←</span> Back to {presentation.name}
        </a>
      </footer>
    </article>
  </div>
</main>

<style>
  /* The Project's own readable page: a dark detail view continuous with the Showcase
     "cosmos" world, carrying the Project's accent as its identity colour. */
  .project {
    --ink: var(--color-fg, oklch(0.96 0.01 260));
    --ink-soft: color-mix(in oklch, var(--ink) 70%, transparent);
    --line: color-mix(in oklch, var(--ink) 14%, transparent);
    --line-strong: color-mix(in oklch, var(--ink) 28%, transparent);
    /* identity accent: per-Project override (set inline above) or the global token */
    --ac: var(--accent, var(--color-accent, oklch(0.7 0.16 250)));

    min-height: 100dvh;
    color: var(--ink);
    font-family: var(--font-geist), system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    /* deep space base (matches the Showcase) + a faint accent halo at the top */
    background:
      radial-gradient(110% 70% at 50% -8%, color-mix(in oklch, var(--ac) 20%, transparent), transparent 58%),
      var(--space, var(--color-bg, #020206));
  }

  .shell {
    max-width: 54rem;
    margin-inline: auto;
    padding: clamp(1.5rem, 5vw, 4rem) clamp(1.25rem, 5vw, 2rem) clamp(3rem, 7vw, 5rem);
  }

  /* ---------- back link (mono, engineer signal) ---------- */
  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
    font-family: var(--font-geist-mono), ui-monospace, monospace;
    font-size: 0.85rem;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.18s ease;
  }
  .back .arrow {
    color: var(--ac);
    transition: transform 0.18s ease;
  }
  .back:hover { color: var(--ink); }
  .back:hover .arrow { transform: translateX(-3px); }
  .back--top { margin-bottom: clamp(2rem, 5vw, 3.25rem); }
  .back:focus-visible {
    outline: 2px solid var(--ac);
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* ---------- header ---------- */
  .eyebrow {
    margin: 0 0 0.9rem;
    font-family: var(--font-geist-mono), ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ac);
  }
  h1 {
    margin: 0 0 0.7rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.03;
    font-size: clamp(2.1rem, 6vw, 3.4rem);
  }
  .summary {
    margin: 0;
    max-width: 42rem;
    font-size: clamp(1.1rem, 2.1vw, 1.35rem);
    line-height: 1.45;
    color: var(--ink-soft);
  }

  /* ---------- meta: stack + links ---------- */
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.9rem 1.5rem;
    margin-top: 1.6rem;
  }
  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .stack li {
    font-family: var(--font-geist-mono), ui-monospace, monospace;
    font-size: 0.76rem;
    letter-spacing: 0.01em;
    padding: 0.3em 0.75em;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--ink-soft);
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45ch;
    font-family: var(--font-geist-mono), ui-monospace, monospace;
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--ink);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.45em 0.95em;
    transition: border-color 0.18s ease, color 0.18s ease, background 0.18s ease;
  }
  .pill .ext { color: var(--ac); }
  .pill:hover {
    color: var(--ac);
    border-color: var(--ac);
    background: color-mix(in oklch, var(--ac) 10%, transparent);
  }
  .pill:focus-visible {
    outline: 2px solid var(--ac);
    outline-offset: 3px;
  }

  /* accent rule separating the header from the media */
  .head {
    padding-bottom: clamp(1.75rem, 4vw, 2.5rem);
    border-bottom: 1px solid var(--line);
    position: relative;
  }
  .head::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 3.5rem;
    height: 2px;
    background: var(--ac);
  }

  /* ---------- media ---------- */
  .media {
    display: grid;
    gap: clamp(0.9rem, 2.5vw, 1.4rem);
    margin: clamp(1.75rem, 4vw, 2.75rem) 0;
  }
  .frame {
    width: 100%;
    height: auto;
    border-radius: var(--stage-inner-radius, 9px);
    border: 1px solid var(--line);
    background: color-mix(in oklch, var(--ink) 4%, transparent);
    box-shadow: 0 1px 0 color-mix(in oklch, var(--ink) 6%, transparent),
      0 18px 40px -24px rgba(0, 0, 0, 0.8);
  }

  /* ---------- prose body ---------- */
  .body {
    font-size: 1.075rem;
    line-height: 1.7;
    color: color-mix(in oklch, var(--ink) 88%, transparent);
    max-width: 42rem;
  }
  .body :global(p) { margin: 0 0 1.15rem; }
  .body :global(p:last-child) { margin-bottom: 0; }
  .body :global(a) {
    color: var(--ac);
    text-underline-offset: 2px;
  }
  .body :global(h2),
  .body :global(h3) {
    margin: 2rem 0 0.75rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .body :global(h2) { font-size: 1.5rem; }
  .body :global(h3) { font-size: 1.2rem; }
  .body :global(ul),
  .body :global(ol) { margin: 0 0 1.15rem; padding-left: 1.3rem; }
  .body :global(li) { margin: 0.3rem 0; }
  .body :global(code) {
    font-family: var(--font-geist-mono), ui-monospace, monospace;
    font-size: 0.9em;
    background: color-mix(in oklch, var(--ink) 10%, transparent);
    border: 1px solid var(--line);
    padding: 0.1em 0.4em;
    border-radius: 5px;
  }
  .body :global(pre) {
    background: color-mix(in oklch, var(--ink) 6%, transparent);
    border: 1px solid var(--line);
    border-radius: var(--radius-base, 0.5rem);
    padding: 1rem 1.1rem;
    overflow-x: auto;
    margin: 0 0 1.15rem;
  }
  .body :global(pre code) { background: none; border: 0; padding: 0; }

  /* ---------- footer ---------- */
  .foot {
    margin-top: clamp(2.5rem, 6vw, 4rem);
    padding-top: clamp(1.5rem, 4vw, 2rem);
    border-top: 1px solid var(--line);
  }

  @media (prefers-reduced-motion: reduce) {
    .back,
    .back .arrow,
    .pill {
      transition: none;
    }
    .back:hover .arrow { transform: none; }
  }
</style>
