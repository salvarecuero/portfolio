---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import wall from "../assets/presentation/wall.webp";
import { presentation } from "../data/presentation";

interface Props {
  entry: CollectionEntry<"projects">;
}
const { entry } = Astro.props;
const { title, summary, stack, links, media, accent, description } = entry.data;
// Per-Project identity: the page wears the Project's accent (token override, like the
// Showcase chrome). The wall texture is carried as a CSS var on the same inline style
// (avoids combining define:vars with an explicit style attr on the root). Accent falls
// back to the global --accent when a Project sets none.
const rootStyle = [
  `--wall-img:url("${wall.src}")`,
  accent ? `--accent:${accent}` : null,
].filter(Boolean).join(";");
// Optional media caption: the live host (e.g. "rangetube.netlify.app").
const liveHost = links?.live ? new URL(links.live).host : null;
---

<main class="project" style={rootStyle}>
  <header class="hero">
    <div class="hero-in">
      <a class="back back--top" href="/">
        <span class="arrow" aria-hidden="true">←</span> {presentation.name}
      </a>

      <p class="eyebrow">Project</p>
      <h1>{title}</h1>
      <p class="summary">{summary}</p>

      {(stack.length > 0 || links?.live || links?.repo) && (
        <div class="meta">
          {stack.length > 0 && (
            <ul class="stack" aria-label="Stack">
              {stack.map((t) => <li>{t}</li>)}
            </ul>
          )}

          {(links?.live || links?.repo) && (
            <nav class="links" aria-label="Project links">
              {links?.live && (
                <a class="pill" href={links.live} target="_blank" rel="noopener">
                  Live site <span class="ext" aria-hidden="true">↗</span>
                </a>
              )}
              {links?.repo && (
                <a class="pill" href={links.repo} target="_blank" rel="noopener">
                  Repository <span class="ext" aria-hidden="true">↗</span>
                </a>
              )}
            </nav>
          )}
        </div>
      )}
    </div>
  </header>

  <div class="shell">
    <div class="media">
      {media.map((m, i) => (
        <figure class="mat">
          {m.type === "image" ? (
            <Image
              class="frame"
              src={m.src}
              alt={m.alt}
              widths={[480, 960, 1440]}
              sizes="(max-width: 860px) 100vw, 820px"
            />
          ) : (
            <video class="frame" controls playsinline poster={m.poster.src} aria-label={m.alt}>
              {m.sources.map((s) => <source src={s.src} type={s.type} />)}
            </video>
          )}
          {i === 0 && liveHost && <figcaption class="cap">{liveHost}</figcaption>}
        </figure>
      ))}
    </div>

    <div class="body">
      {description.map((p) => <p class="body-p">{p}</p>)}
    </div>

    <footer class="foot">
      <a class="back" href="/">
        <span class="arrow" aria-hidden="true">←</span> Back to {presentation.name}
      </a>
    </footer>
  </div>
</main>

<style>
  /* The Project's own readable page: the warm, light "wall" world of the Presentation,
     carrying the Project's accent as its identity colour, with a deliberate dark media
     mat as the guiño to the Showcase cosmos. */
  .project {
    /* warm light palette, scoped here (not in the global tokens) */
    --ink: #26221f;          /* warm charcoal, never pure black */
    --ink-body: #36312c;     /* long-form body copy, softened a touch off --ink */
    --ink-soft: #5f5a53;
    --wall-fallback: #eef0f1;
    --line: rgba(38, 34, 31, 0.12);
    /* identity accent: per-Project override (set inline above) or the global token */
    --ac: var(--accent, var(--color-accent, oklch(0.7 0.16 250)));

    min-height: 100dvh;
    color: var(--ink);
    background: var(--wall-fallback);
    font-family: var(--font-geist), system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  /* ---------- hero band ---------- */
  .hero {
    position: relative;
    background:
      radial-gradient(120% 140% at 100% 0%, color-mix(in oklch, var(--ac) 22%, transparent), transparent 55%),
      var(--wall-img) center / cover no-repeat,
      var(--wall-fallback);
    border-bottom: 1px solid var(--line);
  }
  .hero::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 4rem;
    height: 3px;
    background: var(--ac);
  }
  .hero-in {
    max-width: 54rem;
    margin-inline: auto;
    padding: clamp(1.5rem, 5vw, 3rem) clamp(1.25rem, 5vw, 2.5rem) clamp(1.75rem, 4vw, 2.5rem);
  }

  /* ---------- back link (mono, engineer signal) ---------- */
  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
    font-family: var(--font-geist-mono), ui-monospace, monospace;
    font-size: 0.85rem;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.18s ease;
  }
  .back .arrow {
    color: var(--ac);
    transition: transform 0.18s ease;
  }
  .back:hover { color: var(--ink); }
  .back:hover .arrow { transform: translateX(-3px); }
  .back--top { margin-bottom: clamp(1.5rem, 4vw, 2.25rem); }
  .back:focus-visible {
    outline: 2px solid var(--ac);
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* ---------- header text ---------- */
  .eyebrow {
    margin: 0 0 0.85rem;
    font-family: var(--font-geist-mono), ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ac);
  }
  h1 {
    margin: 0 0 0.7rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.03;
    font-size: clamp(2.1rem, 6vw, 3.4rem);
  }
  .summary {
    margin: 0;
    max-width: 36rem;
    font-size: clamp(1.08rem, 2.1vw, 1.3rem);
    line-height: 1.45;
    color: var(--ink-soft);
  }

  /* ---------- meta: stack + links (one row, wraps) ---------- */
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.7rem 1.4rem;
    margin-top: 1.6rem;
  }
  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .stack li {
    font-family: var(--font-geist-mono), ui-monospace, monospace;
    font-size: 0.76rem;
    letter-spacing: 0.01em;
    padding: 0.3em 0.75em;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
    color: var(--ink-soft);
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }
  /* solid ink pill so the call-to-action reads against the light band */
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
    font-family: var(--font-geist-mono), ui-monospace, monospace;
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    color: #f3f1ec;
    background: var(--ink);
    border: 1px solid var(--ink);
    border-radius: 9px;
    padding: 0.5em 0.95em;
    transition: background 0.18s ease;
  }
  .pill .ext { color: color-mix(in oklch, var(--ac) 75%, white); }
  .pill:hover { background: color-mix(in oklch, var(--ink) 85%, #000); }
  .pill:focus-visible {
    outline: 2px solid var(--ac);
    outline-offset: 3px;
  }

  /* ---------- body region ---------- */
  .shell {
    max-width: 54rem;
    margin-inline: auto;
    padding: clamp(1.75rem, 4vw, 2.75rem) clamp(1.25rem, 5vw, 2.5rem) clamp(3rem, 7vw, 5rem);
  }

  /* media on a dark mat (the guiño to the Showcase) */
  .media {
    display: grid;
    gap: clamp(0.9rem, 2.5vw, 1.4rem);
    margin: 0 0 clamp(2rem, 4vw, 2.75rem);
  }
  .mat {
    margin: 0;
    background: #14110f;
    border-radius: 14px;
    padding: clamp(0.7rem, 2vw, 1.1rem);
    box-shadow: 0 24px 50px -28px rgba(0, 0, 0, 0.6);
  }
  .frame {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--stage-inner-radius, 9px);
  }
  .cap {
    font-family: var(--font-geist-mono), ui-monospace, monospace;
    font-size: 0.7rem;
    color: #8a857c;
    padding: 0.6rem 0.2rem 0.1rem;
  }

  /* prose: narrower reading column for a comfortable line length */
  .body {
    font-size: 1.07rem;
    line-height: 1.72;
    color: var(--ink-body);
    max-width: 38rem;
  }
  .body-p { margin: 0 0 1.15rem; }
  .body-p:last-child { margin-bottom: 0; }

  /* ---------- footer ---------- */
  .foot {
    margin-top: clamp(2.5rem, 6vw, 4rem);
    padding-top: clamp(1.5rem, 4vw, 2rem);
    border-top: 1px solid var(--line);
  }

  @media (prefers-reduced-motion: reduce) {
    .back,
    .back .arrow,
    .pill {
      transition: none;
    }
    .back:hover .arrow { transform: none; }
  }
</style>
