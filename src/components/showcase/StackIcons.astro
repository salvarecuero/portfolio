---
import { stackIcons } from "../../data/presentationIcons";

interface Props {
  stack?: string[];
  variant?: "overlay" | "chrome";
}
const { stack = [], variant = "overlay" } = Astro.props as Props;
---

{
  stack.length > 0 && (
    <ul class:list={["stack-icons", `stack-icons--${variant}`]} aria-label="Tech stack">
      {stack.map((tech) => {
        const icon = stackIcons[tech];
        return (
          <li class="stack-ic" tabindex="0" style={icon ? `--brand:${icon.brand}` : undefined}>
            {icon && "path" in icon && (
              <svg viewBox="0 0 24 24" fill="currentColor" role="img" aria-label={tech}>
                <path d={icon.path} />
              </svg>
            )}
            {icon && "mask" in icon && (
              <span
                class="stack-ic__mask"
                role="img"
                aria-label={tech}
                style={`--mask:url('${icon.mask}')`}
              />
            )}
            <span class="stack-ic__tip" aria-hidden="true">
              {tech}
            </span>
          </li>
        );
      })}
    </ul>
  )
}
