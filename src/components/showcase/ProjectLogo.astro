{
  slug === 'simple-tool-stack' ? (
    <span class="tab-logo tab-logo--sts">
      <svg class="tab-logo-mark" viewBox="0 0 32 32" aria-hidden="true">
        <defs>
          <linearGradient id="sts-mark-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="#6366f1" />
            <stop offset="1" stop-color="#06b6d4" />
          </linearGradient>
        </defs>
        <path d="M16 3 L27 9.5 V22.5 L16 29 L5 22.5 V9.5 Z" fill="url(#sts-mark-grad)" />
        <path d="M17 8 L10.5 17 H15 L14 24 L21.5 14 H16.5 Z" fill="#fff" />
      </svg>
      <span class="tab-logo-word">Simple Tools</span>
    </span>
  ) : slug === 'rangetube' ? (
    <svg class="tab-logo tab-logo--rangetube" viewBox="2 -84 770 96" role="img" aria-label={title}>
      <path d={rangetubeShadow} fill="#042a4a" transform="translate(5 6)" />
      <path d={rangetubeCoral} fill="#e76f51" />
      <path d={rangetubeCream} fill="#fbfbf2" />
    </svg>
  ) : slug === 'bye-bg' ? (
    <span class="tab-logo tab-logo--byebg tab-logo-word">
      <span>bye</span><span class="tab-logo-accent" style={accent ? `color:${accent}` : undefined}>-bg</span>
    </span>
  ) : (
    <>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={iconPath} /></svg>
      <span class="tab-label">{title}</span>
    </>
  )
}
