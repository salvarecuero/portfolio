---
import type { EmbedMode } from "../../lib/showcaseProjects";
interface Props {
  links?: { live?: string; repo?: string };
  title: string;
  slug: string;
  mode: EmbedMode;
  variant?: "overlay" | "chrome";
}
const { links, title, slug, mode, variant = "overlay" } = Astro.props as Props;
const isEmbed = mode === "embed";
// Non-embed Projects link out to the deployed site; embed Projects surface open-in-new-tab in the chrome bar instead.
const liveLabel = "Live site";
---

<nav class:list={["projlinks", `projlinks--${variant}`]} aria-label="Project links">
  <a class="lnk details" href={`/projects/${slug}/`} aria-label={`Details - ${title}`}>
    <svg
      class="icn"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.9"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><circle cx="12" cy="12" r="9"></circle><line x1="12" y1="11" x2="12" y2="16"></line><circle
        cx="12"
        cy="8"
        r="0.6"
        fill="currentColor"
        stroke="none"></circle></svg
    >
    <span class="label">Details</span>
  </a>
  {
    links?.live && !isEmbed && (
      <a
        class="lnk live"
        href={links.live}
        target="_blank"
        rel="noopener"
        aria-label={`${liveLabel} - ${title}`}
      >
        <svg
          class="icn"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.9"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="9" />
          <path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18" />
        </svg>
        <span class="label">{liveLabel}</span>
      </a>
    )
  }
  {
    links?.repo && (
      <a
        class="lnk gh"
        href={links.repo}
        target="_blank"
        rel="noopener"
        aria-label="GitHub"
        data-tip="GitHub"
      >
        <svg class="mark" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 5 18.3 5.3 18.3 5.3c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z" />
        </svg>
      </a>
    )
  }
</nav>
