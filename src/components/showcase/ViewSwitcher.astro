---
// src/components/showcase/ViewSwitcher.astro
// Segmented control for the active embed Stage: Interactive (live embed) vs Screenshots
// (media gallery). One instance lives in the Selector row; viewModeController shows/hides
// it per active Project and keeps aria-pressed / disabled in sync. SSR default = Interactive.
interface Props {
  visible: boolean; // the default active Project is an embed Project
}
const { visible } = Astro.props as Props;
---

<div class="view-switch" role="group" aria-label="Stage view" data-view-switch hidden={!visible}>
  <button class="view-switch__btn" type="button" data-view-set="embed" aria-pressed="true">
    <svg
      class="view-switch__icn"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m13 13 6 6"></path>
      <path d="M3 3l7.5 18 2.5-7.5L20.5 11 3 3z"></path>
    </svg>
    <span class="view-switch__label">Interactive</span>
  </button>
  <button class="view-switch__btn" type="button" data-view-set="media" aria-pressed="false">
    <svg
      class="view-switch__icn"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <rect x="3" y="3" width="18" height="18" rx="2"></rect>
      <circle cx="9" cy="9" r="2"></circle>
      <path d="m21 15-4.5-4.5L5 21"></path>
    </svg>
    <span class="view-switch__label">Screenshots</span>
  </button>
</div>
