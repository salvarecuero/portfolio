---
import { Image } from "astro:assets";
import photo from "../assets/salvador-recuero.jpg";
import { presentation } from "../data/presentation";
import PersonSchema from "./PersonSchema.astro";

const { name, role, stack } = presentation;
const imageUrl = new URL(photo.src, Astro.site ?? `${presentation.domain}/`).href;
---

<section class="presentation">
  <div class="intro">
    <h1>{name}</h1>
    <p class="role">{role}</p>
    <ul class="stack">
      {stack.map((tech) => <li>{tech}</li>)}
    </ul>
  </div>

  <Image
    class="photo"
    src={photo}
    alt={`Photo of ${name}`}
    widths={[400, 600, 800]}
    sizes="(max-width: 768px) 56vw, 30vw"
    loading="eager"
    fetchpriority="high"
  />

  <a class="cue" href="#showcase">Scroll<span aria-hidden="true">↓</span></a>

  <PersonSchema imageUrl={imageUrl} />
</section>

<style>
  .presentation {
    position: relative;
    min-height: 100dvh;
    scroll-snap-align: start;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 2.5rem;
    padding-inline: clamp(1.5rem, 6vw, 5rem);
    overflow: hidden;
  }

  /* Soft radial glow behind the content — atmosphere over a flat background.
     Anchored to the accent so it ties into the identity color. */
  /* Depends on .presentation having no background / stacking context so the z-index:-1 glow shows. */
  .presentation::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      62% 58% at 72% 38%,
      oklch(from var(--color-accent) l c h / 0.16),
      transparent 70%
    );
    pointer-events: none;
    z-index: -1;
  }

  .intro {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  h1 {
    margin: 0;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    font-size: clamp(2.75rem, 6.5vw, 4.5rem);
    max-width: 12ch;
    text-wrap: balance;
  }

  .role {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    align-self: flex-start;
    color: var(--color-accent);
    font-weight: 500;
    font-size: clamp(1rem, 2vw, 1.25rem);
    letter-spacing: 0.01em;
  }

  /* Accent tick before the role for a small editorial detail. */
  .role::before {
    content: "";
    width: 1.75rem;
    height: 1px;
    background: currentColor;
    opacity: 0.7;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .stack li {
    font-size: 0.8125rem;
    line-height: 1;
    /* Solid fallbacks first; relative-color oklch overrides on evergreen browsers (Baseline 2024). */
    color: #9a9ba3;
    color: oklch(from var(--color-fg) l c h / 0.62);
    background: rgba(255, 255, 255, 0.03);
    background: oklch(from var(--color-fg) l c h / 0.03);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border: 1px solid oklch(from var(--color-fg) l c h / 0.14);
    border-radius: 999px;
    padding: 0.4rem 0.8rem;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .stack li:hover {
    color: var(--color-fg);
    border-color: rgba(255, 255, 255, 0.28);
    border-color: oklch(from var(--color-fg) l c h / 0.28);
  }

  .photo {
    width: 78%;
    height: auto;
    justify-self: center;
    aspect-ratio: 1;
    object-fit: cover;
    -webkit-mask-image: linear-gradient(to bottom, #000 46%, transparent 99%);
    mask-image: linear-gradient(to bottom, #000 46%, transparent 99%);
  }

  .cue {
    position: absolute;
    left: 50%;
    bottom: 1.75rem;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    /* Solid fallback first; relative-color oklch overrides on evergreen browsers (Baseline 2024). */
    color: #8a8b93;
    color: oklch(from var(--color-fg) l c h / 0.5);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .cue:hover,
  .cue:focus-visible {
    color: var(--color-fg);
  }

  .cue:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 6px;
    border-radius: 4px;
  }

  .cue span {
    font-size: 1rem;
    line-height: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .cue span { animation: cue-bounce 1.8s ease-in-out infinite; }
  }

  @keyframes cue-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  @media (max-width: 768px) {
    .presentation {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      text-align: center;
    }
    .presentation::before {
      background: radial-gradient(
        70% 40% at 50% 30%,
        oklch(from var(--color-accent) l c h / 0.16),
        transparent 70%
      );
    }
    .intro { align-items: center; order: 1; }
    .role { align-self: center; }
    .photo { width: 56%; order: 2; }
    h1 { max-width: none; }
    .stack { justify-content: center; }
  }
</style>
