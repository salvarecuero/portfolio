---
import photo from "../assets/salvador-recuero.jpg";
import { presentation } from "../data/presentation";
import PresentationContent from "./PresentationContent.astro";
import PersonSchema from "./PersonSchema.astro";

// schema.org/Person image: the original photo (solid, no transparency), absolute URL.
const imageUrl = new URL(photo.src, Astro.site ?? `${presentation.domain}/`).href;
---

<section class="presentation">
  <PresentationContent heading="h1" priority />
  <a class="cue" href="#showcase">Scroll<span aria-hidden="true">↓</span></a>
  <PersonSchema imageUrl={imageUrl} />
</section>

<style>
  /* Frame only — the world (wall/vars/band) lives in PresentationContent.
     The cue is a sibling of `.pres-world`, so the ink palette it references does NOT
     cascade from there; the values it needs are re-declared on `.presentation`. */
  .presentation {
    --p-ink: #26221f; /* warm charcoal, never pure black */
    --p-ink-faint: #938d84;

    position: relative;
    min-height: 100dvh;
    scroll-snap-align: start;
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .cue {
    position: absolute;
    left: 50%;
    bottom: 1.75rem;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: var(--p-ink-faint);
    font-family: var(--font-geist-mono), ui-monospace, monospace;
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .cue:hover,
  .cue:focus-visible {
    color: var(--p-ink);
  }
  .cue:focus-visible {
    outline: 2px solid var(--p-ink);
    outline-offset: 6px;
    border-radius: 4px;
  }
  .cue span {
    font-size: 1rem;
    line-height: 1;
  }
  @media (prefers-reduced-motion: no-preference) {
    .cue span {
      animation: cue-bounce 1.8s ease-in-out infinite;
    }
  }
  @keyframes cue-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }
</style>
