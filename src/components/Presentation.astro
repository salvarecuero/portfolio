---
import { Image } from "astro:assets";
import photo from "../assets/salvador-recuero.jpg";
import subject from "../assets/presentation/subject.png";
import wall from "../assets/presentation/wall.webp";
import { presentation } from "../data/presentation";
import { stackIcons } from "../data/presentationIcons";
import ProfilePageSchema from "./ProfilePageSchema.astro";
import { siteOrigin } from "../lib/seo";

const { name, role, stack, socials, email } = presentation;
// Standout word by weight: given name 600, family name 300 (no accent colour).
const [givenName, ...familyParts] = name.split(" ");
const familyName = familyParts.join(" ");
// schema.org/Person image: the original photo (solid, no transparency), absolute URL.
const imageUrl = new URL(photo.src, siteOrigin(Astro.site, presentation.domain)).href;
---

<section class="presentation">
  <div class="band">
    <div class="intro">
      <h1><span class="given">{givenName} </span><span class="family">{familyName}</span></h1>
      <p class="role">{role}</p>

      {/* Strapline: per-word kinetic typography (the app) + a terminal chip (the code).
          Each word embodies its meaning; unified by the accent so the pieces coexist. */}
      <p class="tagline">
        <span class="word w-beautiful">Beautiful</span><span class="comma">,</span>
        <span class="word w-fast"
          ><span class="streaks back" aria-hidden="true"><i></i><i></i><i></i></span
          ><span class="label"><span class="ch">f</span><span class="ch">a</span><span class="ch">s</span><span class="ch">t</span></span
          ><span class="streaks front" aria-hidden="true"><i></i><i></i><i></i></span
        ></span><span class="comma">,</span>
        <span class="word w-reliable">reliable</span>
        <span class="w-apps">apps.</span>
        <span class="chip">Clean, <span class="tok">solid</span> code.</span>
      </p>

      <ul class="stack">
        {stack.map((tech) => {
          const icon = stackIcons[tech];
          return (
            <li style={icon ? `--brand:${icon.brand}` : undefined}>
              {icon && "path" in icon && (
                <svg class="stack-ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={icon.path} />
                </svg>
              )}
              <span class="stack-lb">{tech}</span>
            </li>
          );
        })}
      </ul>

      <nav class="links" aria-label="Profiles">
        <a class="lnk" data-b="gh" href={socials.github} aria-label="GitHub" target="_blank" rel="noopener">
          <svg class="mark" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 5 18.3 5.3 18.3 5.3c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/></svg>
          <svg class="wm wm-gh" viewBox="0 92 128 38" fill="currentColor" aria-hidden="true"><path d="M24.855 108.302h-10.7a.5.5 0 00-.5.5v5.232a.5.5 0 00.5.5h4.173v6.5s-.937.32-3.53.32c-3.056 0-7.327-1.116-7.327-10.508 0-9.393 4.448-10.63 8.624-10.63 3.614 0 5.17.636 6.162.943.31.094.6-.216.6-.492l1.193-5.055a.468.468 0 00-.192-.39c-.403-.288-2.857-1.66-9.058-1.66-7.144 0-14.472 3.038-14.472 17.65 0 14.61 8.39 16.787 15.46 16.787 5.854 0 9.405-2.502 9.405-2.502.146-.08.162-.285.162-.38v-16.316a.5.5 0 00-.5-.5zM79.506 94.81H73.48a.5.5 0 00-.498.503l.002 11.644h-9.392V95.313a.5.5 0 00-.497-.503H57.07a.5.5 0 00-.498.503v31.53c0 .277.224.503.498.503h6.025a.5.5 0 00.497-.504v-13.486h9.392l-.016 13.486c0 .278.224.504.5.504h6.038a.5.5 0 00.497-.504v-31.53a.497.497 0 00-.497-.502zm-47.166.717c-2.144 0-3.884 1.753-3.884 3.923 0 2.167 1.74 3.925 3.884 3.925 2.146 0 3.885-1.758 3.885-3.925 0-2.17-1.74-3.923-3.885-3.923zm2.956 9.608H29.29c-.276 0-.522.284-.522.56v20.852c0 .613.382.795.876.795h5.41c.595 0 .74-.292.74-.805v-20.899a.5.5 0 00-.498-.502zm67.606.047h-5.98a.5.5 0 00-.496.504v15.46s-1.52 1.11-3.675 1.11-2.727-.977-2.727-3.088v-13.482a.5.5 0 00-.497-.504h-6.068a.502.502 0 00-.498.504v14.502c0 6.27 3.495 7.804 8.302 7.804 3.944 0 7.124-2.18 7.124-2.18s.15 1.15.22 1.285c.07.136.247.273.44.273l3.86-.017a.502.502 0 00.5-.504l-.003-21.166a.504.504 0 00-.5-.502zm16.342-.708c-3.396 0-5.706 1.515-5.706 1.515V95.312a.5.5 0 00-.497-.503H107a.5.5 0 00-.5.503v31.53a.5.5 0 00.5.503h4.192c.19 0 .332-.097.437-.268.103-.17.254-1.454.254-1.454s2.47 2.34 7.148 2.34c5.49 0 8.64-2.784 8.64-12.502s-5.03-10.988-8.428-10.988zm-2.36 17.764c-2.073-.063-3.48-1.004-3.48-1.004v-9.985s1.388-.85 3.09-1.004c2.153-.193 4.228.458 4.228 5.594 0 5.417-.935 6.486-3.837 6.398zm-63.689-.118c-.263 0-.937.107-1.63.107-2.22 0-2.973-1.032-2.973-2.368v-8.866h4.52a.5.5 0 00.5-.504v-4.856a.5.5 0 00-.5-.502h-4.52l-.007-5.97c0-.227-.116-.34-.378-.34h-6.16c-.238 0-.367.106-.367.335v6.17s-3.087.745-3.295.805a.5.5 0 00-.36.48v3.877a.5.5 0 00.497.503h3.158v9.328c0 6.93 4.86 7.61 8.14 7.61 1.497 0 3.29-.48 3.586-.59.18-.067.283-.252.283-.453l.004-4.265a.51.51 0 00-.5-.502z"/></svg>
        </a>
        <a class="lnk" data-b="li" href={socials.linkedin} aria-label="LinkedIn" target="_blank" rel="noopener">
          <svg class="wm wm-li" viewBox="0 45 128 37" fill="currentColor" aria-hidden="true"><path d="M.85 51.73h4.94v17.98h9.14v4.56H.85V51.73zM17.11 59h4.74v15.26h-4.74zm2.37-7.59a2.75 2.75 0 11-2.75 2.75 2.75 2.75 0 012.75-2.75M41.69 51.73h4.74V65.2l5.38-6.22h5.81l-6.22 7.07 6.09 8.22h-5.96l-5.04-7.55h-.06v7.55h-4.74V51.73zM24.48 59H29v2.09h.06a5 5 0 014.49-2.47c4.81 0 5.69 3.16 5.69 7.27v8.38h-4.7v-7.43c0-1.77 0-4-2.47-4s-2.85 1.93-2.85 3.92v7.55h-4.74z"/><path d="M67.61 64.85a2.84 2.84 0 00-2.91-2.91 3.16 3.16 0 00-3.35 2.91zm4 6.77a8.35 8.35 0 01-6.48 3c-4.74 0-8.54-3.16-8.54-8.07s3.8-8.06 8.54-8.06c4.43 0 7.21 3.16 7.21 8.06v1.49h-11a3.54 3.54 0 003.57 3 4 4 0 003.38-1.87zM82.23 62.68A3.89 3.89 0 1086 66.57a3.6 3.6 0 00-3.8-3.89m8.2 11.58H86v-2a6 6 0 01-4.71 2.4c-4.56 0-7.56-3.29-7.56-7.94 0-4.27 2.66-8.19 7-8.19a5.73 5.73 0 014.87 2h.06v-8.8h4.74z"/><path d="M124.6 47H97.36A2.33 2.33 0 0095 49.34v27.35A2.33 2.33 0 0097.36 79h27.24a2.34 2.34 0 002.4-2.31V49.34a2.34 2.34 0 00-2.4-2.34zm-20.12 27.27h-4.74V59h4.74zm-2.37-17.34a2.75 2.75 0 112.75-2.75 2.75 2.75 0 01-2.75 2.75zm20.13 17.34h-4.74v-7.42c0-1.77 0-4-2.46-4s-2.85 1.93-2.85 3.92v7.55h-4.74V59H112v2.1h.06a5 5 0 014.49-2.46c4.8 0 5.69 3.16 5.69 7.27z"/></svg>
        </a>

        {/* Contact: the email address with a copy (JS-only, progressively enhanced) and a
            mailto send action. Neutral ink - our own action, off the accent, like the
            former CV pill. */}
        <div class="contact" data-email={email}>
          <span class="contact-addr">{email}</span>
          <button type="button" class="contact-btn contact-copy" aria-label="Copy email address">
            <span class="ic-wrap">
              <svg class="ic ic-copy" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2"/></svg>
              <svg class="ic ic-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
            <span class="tip" aria-hidden="true">Copy</span>
          </button>
          <a class="contact-btn contact-send" href={`mailto:${email}`} aria-label="Send email">
            <svg class="ic" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
            <span class="tip" aria-hidden="true">Email</span>
          </a>
          <span class="sr-only" role="status" aria-live="polite" data-copy-status></span>
        </div>
      </nav>
    </div>

    <Image
      class="subject"
      src={subject}
      alt={`Photo of ${name}`}
      widths={[400, 480, 600, 800]}
      sizes="(min-width: 1180px) 600px, (min-width: 655px) 380px, 58vw"
      format="webp"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <a class="cue" href="#showcase" data-scroll-cue>
    <span class="cue-label" data-scroll-cue-label>Scroll</span>
    <span class="cue-arrow" aria-hidden="true" data-scroll-cue-arrow>↓</span>
  </a>

  <ProfilePageSchema imageUrl={imageUrl} />
</section>

<script>
  // Copy-to-clipboard for the contact email. Progressive enhancement: the button is
  // CSS-hidden until `html.js`, and the mailto + visible address work without this.
  const box = document.querySelector<HTMLElement>(".contact");
  const btn = box?.querySelector<HTMLButtonElement>(".contact-copy");
  if (box && btn) {
    const tip = btn.querySelector<HTMLElement>(".tip");
    const status = box.querySelector<HTMLElement>("[data-copy-status]");
    const email = box.dataset.email ?? "";
    let timer: number | undefined;
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(email);
      } catch {
        return; // clipboard blocked - the address is still visible and selectable
      }
      btn.classList.add("is-copied");
      if (tip) tip.textContent = "Copied!";
      if (status) status.textContent = "Email address copied";
      clearTimeout(timer);
      timer = window.setTimeout(() => {
        btn.classList.remove("is-copied");
        if (tip) tip.textContent = "Copy";
        if (status) status.textContent = "";
      }, 1600);
    });
  }

  // Wind: the "fast" word floats and ripples only while the pointer is moving, then
  // eases back to rest after a short idle. Pointer-driven so the motion is
  // intentional rather than relying on the browser pausing idle CSS animations.
  // Disabled under reduced motion (the word then never animates).
  const fast = document.querySelector<HTMLElement>(".w-fast");
  if (fast && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const letters = Array.from(fast.querySelectorAll<HTMLElement>(".ch"));
    const parts = [fast, ...letters];
    const restTransform = (el: HTMLElement) => (el === fast ? "skewX(-11deg)" : "none");
    let windTimer: number | undefined;
    let settling = false;

    const clearInline = () => {
      parts.forEach((el) => (el.style.transform = ""));
      settling = false;
    };

    const windOn = () => {
      if (settling) clearInline(); // abandon the in-flight settle; the animation takes over
      fast.classList.add("is-wind");
    };

    // Hand the keyframe animation off to a transition: pin the live transform inline,
    // remove the animation, then set the rest value so `transition: transform` eases
    // it home. Removing an animation alone does not fire a transition (the word would
    // snap), so the handoff is what makes the settle smooth.
    const windOff = () => {
      const from = parts.map((el) => getComputedStyle(el).transform);
      parts.forEach((el, i) => (el.style.transform = from[i]));
      fast.classList.remove("is-wind");
      void fast.offsetWidth; // reflow so `from` becomes the transition's start value
      settling = true;
      parts.forEach((el) => (el.style.transform = restTransform(el)));
    };

    // once the word's settle transition lands, drop the inline transforms so the
    // next gust starts from the stylesheet's base
    fast.addEventListener("transitionend", (e) => {
      if (settling && e.propertyName === "transform" && e.target === fast) clearInline();
    });

    window.addEventListener(
      "pointermove",
      () => {
        windOn();
        clearTimeout(windTimer);
        windTimer = window.setTimeout(windOff, 500);
      },
      { passive: true },
    );
  }
</script>

<style define:vars={{ wallUrl: `url("${wall.src}")` }}>
  /* Presentation lives in its own light, textured "wall" world (the Showcase stays
     dark / immersive). Palette is scoped here, not in the global tokens. */
  .presentation {
    --p-ink: #26221f; /* warm charcoal, never pure black */
    --p-ink-soft: #5f5a53;
    --p-ink-faint: #938d84;
    --p-wall: #eef0f1; /* fallback under the plate */
    /* accent = "the promise": colours only the strapline message + the chip token/caret.
       Hue "sky" picked in the global colour pass. */
    --accent: #2b8fd6;
    --accent-bright: #3aa6ec;
    /* brand colours for the contact links (always-active) */
    --gh: #181717;
    --li: #0a66c2;

    position: relative;
    min-height: 100dvh;
    scroll-snap-align: start;
    display: grid;
    place-items: center;
    overflow: hidden;
    color: var(--p-ink);
    font-family: var(--font-geist), system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    /* the real bedsheet, extended (see docs/superpowers/specs) */
    background: var(--wallUrl) center / cover no-repeat, var(--p-wall);
  }

  /* centered content band: keeps text and subject close on wide screens.
     Wide max-width + tight inline padding so the text column has room for the
     strapline + code chip to share one row alongside the subject. */
  .band {
    width: 100%;
    max-width: 82rem;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 3vw, 2.25rem);
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3.5rem);
  }

  .intro {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  h1 {
    margin: 0;
    font-family: var(--font-geist), system-ui, sans-serif;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    font-size: clamp(2.3rem, 5.2vw, 4.3rem);
    white-space: nowrap; /* name on one line */
  }
  h1 .family {
    font-weight: 300; /* standout by weight, not colour */
  }

  .role {
    margin: 0;
    margin-top: 0.55rem; /* tight: the role is the subtitle of the name (one identity unit) */
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-geist-mono), ui-monospace, monospace;
    color: var(--p-ink-soft);
    font-weight: 500;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    white-space: nowrap; /* role on one line */
  }
  .role::before {
    content: "";
    width: 2.2rem;
    height: 1.5px;
    background: var(--p-ink-faint);
  }

  /* =================== strapline =================== */
  .tagline {
    margin: 0;
    margin-top: 2rem; /* new block: the promise (strapline) */
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    column-gap: 0.5rem;
    row-gap: 1.2em;
    font-size: clamp(1.2rem, 1.55vw, 1.5rem);
    line-height: 1.25;
  }
  .word {
    position: relative;
    color: var(--accent);
  }
  .comma {
    color: var(--p-ink-soft);
    font-weight: 400;
  }

  /* Beautiful - script */
  .w-beautiful {
    font-family: var(--font-yellowtail), cursive;
    font-size: 1.5em;
    line-height: 1;
    padding-right: 0.1em;
    white-space: nowrap;
  }

  /* fast - leaning condensed + speed streaks (half behind the glyphs, half in front) */
  .w-fast {
    position: relative;
    font-family: var(--font-oswald), sans-serif;
    font-weight: 600;
    /* resting lean; fast-float folds it into its keyframes since the animation
       overrides transform. The transition eases the word back to rest when the
       wind (pointer movement) stops and the .is-wind animation is removed. */
    transform: skewX(-11deg);
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    letter-spacing: -0.005em;
    padding: 0 0.14em;
    display: inline-block;
  }
  .w-fast .label {
    position: relative;
    z-index: 1;
    color: var(--accent);
  }
  .w-fast .ch {
    display: inline-block;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* The float and per-letter ripple run only while there is "wind": the script
     adds .is-wind on pointer movement and removes it after a short idle, so the
     motion is intentional rather than relying on the browser's idle-frame
     throttling. Without JS (or at rest) the word stays still. Both are
     transform-only, so the line never reflows - neighbours stay put.
     fast-float drifts the whole word (X and Y peaks offset for an organic loop);
     the staggered fast-flutter sends a wave across the letters (flag in wind). */
  .w-fast.is-wind {
    animation: fast-float 8s ease-in-out infinite;
  }
  .w-fast.is-wind .ch {
    animation: fast-flutter 2.8s ease-in-out infinite;
  }
  .w-fast.is-wind .ch:nth-child(1) { animation-delay: 0s; }
  .w-fast.is-wind .ch:nth-child(2) { animation-delay: 0.12s; }
  .w-fast.is-wind .ch:nth-child(3) { animation-delay: 0.24s; }
  .w-fast.is-wind .ch:nth-child(4) { animation-delay: 0.36s; }
  .w-fast .streaks {
    position: absolute;
    inset: -28% -10%;
    pointer-events: none;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 15%, #000 85%, transparent 100%);
    mask-image: linear-gradient(90deg, transparent 0, #000 15%, #000 85%, transparent 100%);
  }
  .w-fast .streaks.back { z-index: 0; }
  .w-fast .streaks.front { z-index: 2; }
  .w-fast .streaks i {
    position: absolute;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(90deg, transparent, var(--accent-bright) 65%, var(--accent-bright));
    opacity: 0;
    animation: zip 0.21s linear infinite;
  }
  .w-fast .streaks.front i { height: 1.5px; }
  .w-fast .streaks.back i:nth-child(1) { top: 12%; width: 1.7em; animation-delay: 0s; }
  .w-fast .streaks.back i:nth-child(2) { top: 46%; width: 2em; animation-delay: 0.14s; }
  .w-fast .streaks.back i:nth-child(3) { top: 80%; width: 1.6em; animation-delay: 0.07s; }
  .w-fast .streaks.front i:nth-child(1) { top: 28%; width: 1.3em; animation-delay: 0.21s; }
  .w-fast .streaks.front i:nth-child(2) { top: 62%; width: 1.5em; animation-delay: 0.05s; }
  .w-fast .streaks.front i:nth-child(3) { top: 94%; width: 1.1em; animation-delay: 0.17s; }
  @keyframes zip {
    0% { transform: translateX(150%); opacity: 0; }
    22% { opacity: 0.95; }
    78% { opacity: 0.95; }
    100% { transform: translateX(-190%); opacity: 0; }
  }
  /* organic float: X and Y peak on different keyframes so the path loops rather
     than tracing a straight line. skewX is carried through every step. */
  @keyframes fast-float {
    0%   { transform: translate(0, 0) skewX(-11deg); }
    20%  { transform: translate(0.10em, -0.10em) skewX(-11deg); }
    40%  { transform: translate(-0.06em, -0.14em) skewX(-11deg); }
    60%  { transform: translate(-0.10em, 0.06em) skewX(-11deg); }
    80%  { transform: translate(0.07em, 0.12em) skewX(-11deg); }
    100% { transform: translate(0, 0) skewX(-11deg); }
  }
  /* a full up-then-down wave per letter; staggered delays make it travel. */
  @keyframes fast-flutter {
    0%   { transform: translateY(0) rotate(0deg); }
    25%  { transform: translateY(-0.06em) rotate(-2.5deg); }
    50%  { transform: translateY(0) rotate(0deg); }
    75%  { transform: translateY(0.05em) rotate(2.5deg); }
    100% { transform: translateY(0) rotate(0deg); }
  }

  /* reliable - sturdy slab + a static accent "foundation" underline */
  .w-reliable {
    font-family: var(--font-zilla), serif;
    font-weight: 700;
    padding: 0 0.05em;
    position: relative;
  }
  .w-reliable::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.12em;
    height: 3px;
    border-radius: 2px;
    background: var(--accent);
  }

  /* apps. - neutral connector */
  .w-apps {
    font-family: var(--font-geist), system-ui, sans-serif;
    font-weight: 400;
