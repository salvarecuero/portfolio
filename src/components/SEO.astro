---
import { buildSeoMeta, siteOrigin } from '../lib/seo';
import { buildWebsiteSchema } from '../data/websiteSchema';
import { presentation } from '../data/presentation';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  /** Real pixel dimensions of `image`. Omitted => width/height meta is skipped. */
  imageWidth?: number;
  imageHeight?: number;
  /** og:image alt; defaults to the person descriptor. */
  imageAlt?: string;
  /** Extra JSON-LD node(s) to emit on top of the global WebSite node. */
  jsonLd?: object | object[];
}
const {
  title,
  description = presentation.description,
  image,
  type,
  imageWidth,
  imageHeight,
  imageAlt,
  jsonLd,
} = Astro.props;

const meta = buildSeoMeta({
  site: Astro.site,
  fallbackOrigin: presentation.domain,
  pathname: Astro.url.pathname,
  title,
  description,
  image,
  type,
});
const ogImageAlt = imageAlt ?? `${presentation.name} - ${presentation.role}`;
// Default og.png is a known 1200x630; a per-page image carries its own dimensions (or none).
const ogWidth = image ? imageWidth : 1200;
const ogHeight = image ? imageHeight : 630;
const extraJsonLd = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const origin = siteOrigin(Astro.site, presentation.domain);
const website = buildWebsiteSchema({ siteUrl: origin });
---
<title>{meta.title}</title>
<meta name="description" content={meta.description} />
<link rel="canonical" href={meta.canonical} />

<!-- Favicons (svg primary, ico fallback, apple-touch for iOS), web app manifest, browser chrome colour -->
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#020206" />

<!-- Open Graph -->
<meta property="og:type" content={meta.ogType} />
<meta property="og:title" content={meta.title} />
<meta property="og:description" content={meta.description} />
<meta property="og:url" content={meta.ogUrl} />
<meta property="og:site_name" content={presentation.name} />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={meta.ogImage} />
{ogWidth && ogHeight && <meta property="og:image:width" content={String(ogWidth)} />}
{ogWidth && ogHeight && <meta property="og:image:height" content={String(ogHeight)} />}
<meta property="og:image:alt" content={ogImageAlt} />

<!-- Twitter / X (image reuses og:image) -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={meta.title} />
<meta name="twitter:description" content={meta.description} />
<meta name="twitter:image" content={meta.ogImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />

<!-- Sitemap discovery -->
<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

<!-- WebSite JSON-LD (Person lives in the Presentation) -->
<script type="application/ld+json" is:inline set:html={JSON.stringify(website)} />
{extraJsonLd.map((node) => (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(node)} />
))}
