---
import Layout from "../layouts/Layout.astro";
import Presentation from "../components/Presentation.astro";
import { presentation } from "../data/presentation";

const title = `${presentation.name} — ${presentation.role}`;
---

<Layout title={title} description={presentation.description}>
  <main class="h-dvh snap-y snap-mandatory overflow-y-scroll">
    <Presentation />

    {/* Showcase — see CONTEXT.md, ADR 0002 and 0003. Built separately. */}
    <section id="showcase" class="grid h-dvh snap-start place-items-center">
      <p class="font-sans text-2xl">Showcase</p>
    </section>
  </main>
</Layout>
